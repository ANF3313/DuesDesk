# Copy this file to .env.local and fill in each value.
# .env.local is git-ignored — secrets never leave your machine.

# ── Supabase ─ dashboard: Project Settings → API ──────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-only. Bypasses Row Level Security — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Stripe ─ dashboard: Developers → API keys (Test mode while building) ──
STRIPE_SECRET_KEY=sk_test_...
# Signing secret of your ONE webhook endpoint (listens to Connected accounts).
# Created after first deploy — see README "Going live".
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend ─ dashboard: API Keys ───────────────────────────────────────────
RESEND_API_KEY=re_...
# Before you own a domain: onboarding@resend.dev (delivers only to YOUR email).
# After verifying a domain in Resend: "DuesDesk <dues@yourdomain.com>"
EMAIL_FROM=onboarding@resend.dev

# ── App ────────────────────────────────────────────────────────────────────
# Local dev: http://localhost:3000 · Production: your Vercel URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Random 32+ chars (run: openssl rand -hex 32). Vercel sends it with cron calls.
CRON_SECRET=
